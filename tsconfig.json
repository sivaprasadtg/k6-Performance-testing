{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "types": ["k6","k6/options"],
    "moduleResolution": "Bundler",
    "allowJs": "false",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": false
  },
  "include": ["scripts", "libs", "scenarios", "config", "tools/run.ts"]
}
